# Database (PostgreSQL)
DATABASE_URL="postgresql://user:password@localhost:5432/educonsult?schema=public"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-a-long-random-secret-for-production"

# Token encryption (min 32 chars) - used to encrypt Gmail refresh/access tokens at rest
TOKEN_ENCRYPTION_SECRET="your-32-char-or-longer-secret-key-here"

# Google OAuth - for student Gmail connection (Gmail API)
# Create OAuth 2.0 credentials in Google Cloud Console:
# https://console.cloud.google.com/apis/credentials
# Authorized redirect URIs: http://localhost:3000/api/oauth/gmail/callback (and your production URL)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Optional: same credentials can be used for staff Google sign-in if you add Google provider to NextAuth.

# Rate limiting (DDoS / brute-force) – optional, recommended for production
# Upstash Redis: https://console.upstash.com/ (free tier is enough)
# When set: global API rate limit (middleware) + register/login/sync limits stored in Redis (multi-instance safe)
# UPSTASH_REDIS_REST_URL="https://xxx.upstash.io"
# UPSTASH_REDIS_REST_TOKEN="AXXX..."
